# ============================================================
# Supabase — Dashboard > Settings > API
# ============================================================
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# Twilio — console.twilio.com
# ============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# WhatsApp sender: Twilio sandbox = whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ============================================================
# Pet Shop — Business contact
# ============================================================
# Number for click-to-chat CTAs (no + or spaces, e.g. 5511999999999)
PUBLIC_WHATSAPP_NUMBER=5511999999999
PUBLIC_WHATSAPP_DEFAULT_MESSAGE=Olá! Gostaria de agendar um serviço para meu pet.

# ============================================================
# Mercado Pago — https://www.mercadopago.com.br/developers
# ============================================================
# Access token (server only — nunca exponha ao cliente)
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxx-your-access-token
# Public key (seguro para o browser — aparece na URL do SDK)
PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-xxxx-your-public-key
# Prefixo para idempotency keys (qualquer string)
MERCADOPAGO_IDEMPOTENCY_KEY_PREFIX=arcpetshop

# ============================================================
# Application
# ============================================================
PUBLIC_SITE_URL=http://localhost:5173
PUBLIC_SITE_NAME=ArcPetShop
NODE_ENV=development
